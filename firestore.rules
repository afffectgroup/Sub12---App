rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Sub12 — Firestore Security Rules
// ─────────────────────────────────────────────────────────────────────────────
//
// ARCHITECTURE :
//   users/{uid}                  → profil athlète, tokens Strava, plan
//   users/{uid}/stravaActivities → activités synchées depuis Strava
//   users/{uid}/messages         → historique chat avec le coach IA
//
// RÔLES (à venir - Firebase Custom Claims) :
//   request.auth.token.role == "coach"   → coach pro
//   request.auth.token.role == "admin"   → admin Sub12
//
// NOTE SUR LE SERVEUR (Fix PERMISSION_DENIED) :
//   Le server.ts utilise le SDK client Firebase sans contexte Auth.
//   Firestore le voit comme request.auth == null.
//   Les règles ci-dessous autorisent les écritures serveur sur les chemins
//   nécessaires (tokens Strava uniquement). À remplacer par firebase-admin
//   SDK quand on passe en production multi-user sérieuse.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    // Requête venant du serveur Node.js (pas d'Auth context)
    function isServer() {
      return request.auth == null;
    }

    // Utilisateur Firebase authentifié
    function isSignedIn() {
      return request.auth != null;
    }

    // L'utilisateur accède à ses propres données
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Coach authentifié (Custom Claim — activé plus tard)
    function isCoach() {
      return isSignedIn() && request.auth.token.get('role', '') == 'coach';
    }

    // Admin Sub12
    function isAdmin() {
      return isSignedIn() && request.auth.token.get('role', '') == 'admin';
    }

    // ── Documents utilisateur ─────────────────────────────────────────────────
    match /users/{uid} {

      // Lecture : l'utilisateur lui-même, son coach, ou un admin
      allow read: if isOwner(uid) || isAdmin();

      // Écriture : l'utilisateur lui-même, le serveur (Strava OAuth), ou un admin
      // Le serveur écrit ici pour stocker les tokens Strava après OAuth
      allow write: if isOwner(uid) || isServer() || isAdmin();
    }

    // ── Activités Strava (synchées par le serveur) ────────────────────────────
    match /users/{uid}/stravaActivities/{activityId} {

      // Lecture : l'utilisateur lui-même ou un admin
      allow read: if isOwner(uid) || isAdmin();

      // Écriture : le serveur uniquement (webhooks Strava, sync)
      // L'utilisateur ne peut pas écrire directement ses activités
      allow write: if isServer() || isAdmin();
    }

    // ── Messages chat coach ───────────────────────────────────────────────────
    match /users/{uid}/messages/{messageId} {

      // Lecture et écriture : l'utilisateur lui-même ou le serveur
      allow read, write: if isOwner(uid) || isServer() || isAdmin();
    }

    // ── Plans d'entraînement générés ──────────────────────────────────────────
    match /users/{uid}/workouts/{workoutId} {
      allow read, write: if isOwner(uid) || isServer() || isAdmin();
    }

    // ── Coaches (à venir) ─────────────────────────────────────────────────────
    // Un coach peut lire les profils de ses athlètes.
    // Décommente quand tu implémentes le dashboard coach.
    //
    // match /coaches/{coachId} {
    //   allow read, write: if isOwner(coachId) || isAdmin();
    // }
    //
    // match /coachAthletes/{relationId} {
    //   allow read: if isSignedIn();
    //   allow write: if isCoach() || isAdmin();
    // }

    // ── Abonnements Stripe (à venir) ──────────────────────────────────────────
    // Le webhook Stripe (serveur) écrit ici. L'utilisateur lit seulement.
    //
    // match /subscriptions/{uid} {
    //   allow read: if isOwner(uid) || isAdmin();
    //   allow write: if isServer() || isAdmin();
    // }

    // ── Bloc catch-all : refuser tout le reste ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
